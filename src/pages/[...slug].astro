---
// Renders both blog posts and content pages at their frontmatter slug,
// matching the Gatsby URL scheme (e.g. /dragonlance-reading-order, /about).
import { render } from 'astro:content'
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
// Old site behaviour: articles without a cover show the site cover.
import defaultCover from '../../content/images/cover-dk.jpg'
import BaseLayout from '../layouts/BaseLayout.astro'
import {
  excerpt,
  getPublishedPosts,
  getListedPosts,
  readingTime,
  type Post,
} from '../lib/posts'

export async function getStaticPaths() {
  const posts = await getPublishedPosts()
  const listed = await getListedPosts()
  const pages = await getCollection('pages')

  const postPaths = posts.map(post => {
    // prev/next navigate the listed timeline only (newest first)
    const index = listed.findIndex(p => p.id === post.id)
    return {
      params: { slug: post.data.slug },
      props: {
        entry: post,
        isPost: true,
        previous: index >= 0 ? (listed[index + 1] ?? null) : null,
        next: index > 0 ? listed[index - 1] : null,
      },
    }
  })

  const pagePaths = pages.map(page => ({
    params: { slug: page.data.slug },
    props: { entry: page, isPost: false, previous: null, next: null },
  }))

  return [...postPaths, ...pagePaths]
}

const { entry, isPost, previous, next } = Astro.props
const { Content } = await render(entry)
const description = excerpt(entry.body ?? '')
const cover = entry.data.cover ?? defaultCover
---

<BaseLayout title={entry.data.title} description={description}>
  <article class="card">
    <Image
      class="article-cover"
      src={cover}
      alt={entry.data.title}
      widths={[480, 770, 1540]}
      sizes="(max-width: 800px) 100vw, 770px"
      loading="eager"
    />
    <div class="content-pad">
      <h1 class="article-title">{entry.data.title}</h1>
      <div class="article-meta">
        {
          isPost && (
            <>
              <time datetime={(entry as Post).data.date.toISOString()}>
                {(entry as Post).data.date.toLocaleDateString('en-AU', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <span class="bull" />
              <span class="reading-time">
                {readingTime(entry.body ?? '')} min read
              </span>
              {(entry as Post).data.tags.length > 0 && (
                <>
                  <span class="bull" />
                  <span class="tag-list">
                    {(entry as Post).data.tags.map((tag: string) => (
                      <a href={`/tags/${tag}`}>#{tag}</a>
                    ))}
                  </span>
                </>
              )}
            </>
          )
        }
      </div>
      <div class="article-content">
        <Content />
      </div>
      {
        (previous || next) && (
          <footer class="article-footer">
            <nav class="prev-next">
              {previous ? (
                <a href={`/${previous.data.slug}`}>← {previous.data.title}</a>
              ) : (
                <span />
              )}
              {next ? (
                <a href={`/${next.data.slug}`}>{next.data.title} →</a>
              ) : (
                <span />
              )}
            </nav>
          </footer>
        )
      }
    </div>
  </article>
</BaseLayout>
