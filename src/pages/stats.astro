---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getPelotonData } from '../lib/peloton'

const data = await getPelotonData()
---

<BaseLayout title="My Peloton Stats">
  <h1>My Peloton Stats</h1>
  {
    !data && (
      <p>
        Stats are unavailable right now — data is pulled from the Peloton API
        at build time.
      </p>
    )
  }
  {
    data && (
      <>
        <section>
          <h2>Workouts</h2>
          <div class="stats-grid">
            {data.workoutCounts
              .filter(workoutCount => workoutCount.count > 0)
              .map(workoutCount => (
                <div class="stat-item">
                  <img src={workoutCount.icon_url} alt="" loading="lazy" />
                  <div class="stat-count">{workoutCount.count}</div>
                  <div>{workoutCount.name}</div>
                </div>
              ))}
          </div>
        </section>

        <section>
          <h2>Recent Workouts</h2>
          {data.recentWorkouts.map(workout => (
            <div class="workout-row">
              <img src={workout.instructor?.image_url} alt="" loading="lazy" />
              <div>
                <div>{workout.title}</div>
                <div class="workout-meta">
                  {workout.discipline} · {workout.instructor?.name}
                  {workout.totalwork ? ` · ${workout.totalwork} kJ` : ''}
                  {workout.effortPoints
                    ? ` · ${workout.effortPoints} effort points`
                    : ''}
                </div>
              </div>
            </div>
          ))}
        </section>

        <section>
          <h2>Personal Records</h2>
          {data.records.map(category => (
            <div>
              <h3>{category.name}</h3>
              <div class="stats-grid">
                {category.records.map(record => (
                  <div class="stat-item">
                    <div class="stat-count">{record.value}</div>
                    <div>
                      {record.name} {record.unit}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </section>

        <section>
          <h2>Achievements</h2>
          <div class="stats-grid">
            {data.achievements
              .filter(achievement => achievement.count > 0)
              .map(achievement => (
                <div class="stat-item" title={achievement.description}>
                  <img src={achievement.image_url} alt="" loading="lazy" />
                  <div>{achievement.name}</div>
                  {achievement.count > 1 && (
                    <div class="workout-meta">×{achievement.count}</div>
                  )}
                </div>
              ))}
          </div>
        </section>
      </>
    )
  }
</BaseLayout>
