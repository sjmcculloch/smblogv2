---
// Paginated post list at /pages/2, /pages/3 ... (URL scheme kept from
// the Gatsby site; page 1 is the site root, see ../index.astro).
import BaseLayout from '../../layouts/BaseLayout.astro'
import PostCard from '../../components/PostCard.astro'
import Pagination from '../../components/Pagination.astro'
import { getListedPosts, type Post } from '../../lib/posts'
import { site } from '../../data/site'

export async function getStaticPaths() {
  const posts = await getListedPosts()
  const totalPages = Math.ceil(posts.length / site.postsPerPage)

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const page = i + 2
    return {
      params: { page: String(page) },
      props: {
        posts: posts.slice(
          (page - 1) * site.postsPerPage,
          page * site.postsPerPage
        ),
        currentPage: page,
        totalPages,
      },
    }
  })
}

interface Props {
  posts: Post[]
  currentPage: number
  totalPages: number
}

const { posts, currentPage, totalPages } = Astro.props
---

<BaseLayout title={`Page ${currentPage}`}>
  {posts.map(post => <PostCard post={post} />)}
  <Pagination currentPage={currentPage} totalPages={totalPages} />
</BaseLayout>
